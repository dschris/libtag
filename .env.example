# LibTag Configuration
# All variables are prefixed with LIBTAG_

# Path to media directory (mounted volume)
LIBTAG_MEDIA_PATH=/media

# Ollama endpoint
LIBTAG_OLLAMA_URL=http://ollama:11434
LIBTAG_OLLAMA_MODEL=llama3.1:8b

# Database path (should be on a persistent volume)
LIBTAG_DB_PATH=/data/libtag.db

# File extensions to scan (comma-separated)
LIBTAG_SCAN_EXTENSIONS=.mkv,.mp4,.avi,.mov,.ts,.flac,.mp3,.wav,.aac,.m4a,.m4v,.wmv,.flv,.webm,.ogg,.opus,.srt,.sub,.ass,.ssa,.idx

# Processing
LIBTAG_AUTO_MODE=true
LIBTAG_WORKERS=2
LIBTAG_RENAME_BATCH_SIZE=10

# Server
LIBTAG_HOST=0.0.0.0
LIBTAG_PORT=8080
